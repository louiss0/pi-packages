{
  "name": "pi-form-components",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "pi-form-components",
  "targets": {
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome format --config-path biome.json {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome format --write --config-path biome.json {projectRoot}",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "pnpm exec vite build --config vite.lib.config.ts",
        "cwd": "{projectRoot}"
      }
    },
    "prepare-production-package": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node ../tools/prepare-bundled-package.mjs . ./dist",
        "cwd": "{projectRoot}"
      }
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": ["prepare-production-package"],
      "options": {
        "packageRoot": "pi-form-components/dist"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "{projectRoot}/vitest.config.ts"
      }
    },
    "metadata": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/validate-package-metadata.mjs {projectRoot}"
      }
    }
  },
  "tags": ["npm:public", "scope:shared", "project:package", "status:supported"]
}
