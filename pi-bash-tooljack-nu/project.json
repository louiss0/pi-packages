{
  "name": "pi-bash-tooljack-nu",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "pi-bash-tooljack-nu/src",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.lib.json --noEmit",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "options": {
        "configFile": "{projectRoot}/vitest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["{projectRoot}/**/*.ts", "{projectRoot}/**/*.js"]
      }
    },
    "biome": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome format .",
        "cwd": "{projectRoot}"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome format --write .",
        "cwd": "{projectRoot}"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "dependsOn": ["typecheck", "lint", "test", "metadata"],
      "options": {
        "command": "echo 'All checks passed'"
      }
    },
    "metadata": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/validate-package-metadata.mjs {projectRoot}"
      }
    }
  },
  "tags": ["npm:public", "project:extension", "status:supported"]
}
