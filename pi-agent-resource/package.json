  "bugs": {
    "url": "https://github.com/louiss0/pi-packages/issues"
  },
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@nx/eslint": "22.7.1",
    "@nx/vite": "22.7.1",
    "@nx/vitest": "22.7.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "nx": "22.7.1",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "pi": {
    "extensions": [
