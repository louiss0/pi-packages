{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "vite/client", "vitest/globals", "vitest/importMeta"],
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": ["extensions/**/*.ts", "shared/**/*.ts"],
  "references": [
    {
      "path": "../pi-form-components"
    }
  ]
}
