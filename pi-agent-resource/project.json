{
	"name": "pi-agent-resource",
	"$schema": "../node_modules/nx/schemas/project-schema.json",
	"projectType": "library",
	"root": "pi-agent-resource",
	"targets": {
		"biome": {
			"executor": "nx:run-commands",
			"options": {
				"command": "pnpm exec biome format .",
				"cwd": "{projectRoot}"
			}
		},
		"format": {
			"executor": "nx:run-commands",
			"options": {
				"command": "pnpm exec biome format --write .",
				"cwd": "{projectRoot}"
			}
		},
		"metadata": {
			"executor": "nx:run-commands",
			"options": {
				"command": "node tools/validate-package-metadata.mjs {projectRoot}"
			}
		}
	},
	"tags": ["npm:public", "project:extension", "status:supported"]
}
