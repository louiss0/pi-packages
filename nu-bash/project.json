{
"name": "@code-fixer-23/nu-bash",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "nu-bash/src",
  "targets": {
    "typecheck": {
      "executor": "@nx/js:tsc",
      "options": {
        "main": "{projectRoot}/src/index.ts",
        "outputPath": "dist/{projectName}",
        "tsConfig": "nu-bash/tsconfig.lib.json",
        "noEmit": true,
        "generatePackageJson": false
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir nu-bash run lint"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir nu-bash run format"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/test-output/vitest"],
      "options": {
        "command": "pnpm --dir nu-bash run test"
      }
    }
  },
  "tags": []
}
