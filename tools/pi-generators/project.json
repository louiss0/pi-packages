{
  "name": "@code-fixer-23/pi-generators",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "tools/pi-generators",
  "targets": {
    "biome": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome format .",
        "cwd": "{projectRoot}"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec biome format --write .",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["npm:private"]
}
