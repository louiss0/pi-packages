{
  "type": "module",
  "devDependencies": {
    "typescript": "latest",
    "vitest": "latest"
  },
  "name": "@code-fixer-23/pi-prompt-guard",
  "version": "0.0.1",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Pi package scaffold for pi-prompt-guard",
  "repository": {
    "type": "git",
    "url": "https://github.com/louiss0/pi-packages",
    "directory": "pi-prompt-guard"
  },
  "homepage": "https://github.com/louiss0/pi-packages",
  "bugs": {
    "url": "https://github.com/louiss0/pi-packages/issues"
  },
  "keywords": ["pi-package"],
  "files": [
    "assets",
    "extensions",
    "README.md",
    "!**/*.test.ts"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "extensions",
      "extensions/!*.test.ts"
    ],
    "image": "https://raw.githubusercontent.com/louiss0/pi-packages/main/pi-prompt-guard/assets/small-pi-prompt-guard.png"
  },
  "dependencies": {
    "@code-fixer-23/pi-prompt-parser": "workspace:*"
  }
}
